##   echo "https://dl-cdn.alpinelinux.org/alpine/v3.23/community" >> /etc/apk/repositories

RUN echo "https://mirrors.aliyun.com/alpine/v3.23/main" > /etc/apk/repositories && \
  echo "https://mirrors.aliyun.com/alpine/v3.23/community" >> /etc/apk/repositories

#RUN apk add --update --no-cache ca-certificates bash openssh openssh-server git gcompat tzdata rsync
#RUN apk add --update --no-cache ca-certificates bash git gcompat tzdata rsync procps
RUN apk add --update --no-cache ca-certificates bash gcompat tzdata rsync procps

RUN adduser -h /home/action -s /bin/sh -u 2048 -D action

