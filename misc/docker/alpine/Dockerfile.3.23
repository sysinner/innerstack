FROM alpine:3.23

## RUN echo "https://mirrors.aliyun.com/alpine/v3.23/main" > /etc/apk/repositories && \
##   echo "https://mirrors.aliyun.com/alpine/v3.23/community" >> /etc/apk/repositories && \
