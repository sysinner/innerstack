[Unit]
Description=InnerStack Enterprise PaaS
After=network.target

[Service]
Type=simple
LimitNOFILE=8192
ExecStart=/opt/innerstack/bin/ingated
ExecReload=/bin/kill -HUP $MAINPID

TimeoutStartSec=0

KillMode=process

Restart=always
RestartSec=10

StartLimitBurst=3
StartLimitInterval=60s

StandardOutput=append:/opt/innerstack/var/log/ingate.log
StandardError=append:/opt/innerstack/var/log/ingate-error.log

[Install]
WantedBy=multi-user.target
